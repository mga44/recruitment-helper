# Copy to .env and fill in your values.

# MongoDB connection (defaults shown)
MONGO_URI=mongodb://localhost:27017/recruitment
PORT=5000

# Google OAuth 2.0 credentials for the Calendar integration.
# Create an OAuth client (type: Web application) at https://console.cloud.google.com/apis/credentials
# and add the redirect URI(s) below to its authorized redirect URIs.
# Used as-is for `npm start` (dev, backend on localhost:5000). For
# `docker compose up`, port 5000 isn't published to the host, so
# docker-compose.yml overrides this to http://localhost:8080/api/auth/google/callback
# (routed through nginx) — add BOTH URIs to the Google Cloud Console client.
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:5000/api/auth/google/callback

# Where the OAuth callback redirects back to after connecting
FRONTEND_URL=http://localhost:5173
