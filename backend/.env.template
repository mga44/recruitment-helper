# Copy to .env and fill in your values.

# MongoDB connection (defaults shown)
MONGO_URI=mongodb://localhost:27017/recruitment
PORT=5000

# Google OAuth 2.0 credentials for the Calendar integration.
# Create an OAuth client (type: Web application) at https://console.cloud.google.com/apis/credentials
# and add the redirect URI below to its authorized redirect URIs.
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:5000/api/auth/google/callback

# Where the OAuth callback redirects back to after connecting
FRONTEND_URL=http://localhost:5173
